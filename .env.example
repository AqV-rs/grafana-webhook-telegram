# Telegram bot token (обязательно)
TELEGRAM_BOT_TOKEN=123456789:YOUR_TELEGRAM_BOT_TOKEN

# JSON с маршрутами: endpoint -> список чатов
# Можно указывать:
# - просто chat_id строкой
# - или объект с настройками
ROUTES_JSON={
  "/grafana/prod": [
    "-1001234567890"
  ],
  "/grafana/dev": [
    {"chat_id": "-1005555555555", "message_thread_id": 42}
  ]
}

# Секрет для защиты webhook (опционально)
WEBHOOK_SECRET=supersecret

# Parse mode для Telegram (HTML или MarkdownV2)
PARSE_MODE=HTML

# Хост и порт приложения
HOST=0.0.0.0
PORT=8000